{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BuildLore Configuration",
  "description": "Configuration for the BuildLore VS Code extension",
  "type": "object",
  "properties": {
    "template": {
      "description": "The template to use for styled markdown preview",
      "type": "string",
      "enum": [
        "Standard",
        "Manuscript",
        "Briefing",
        "Scholar",
        "Journal",
        "Dispatch",
        "Handbook",
        "Midnight",
        "Blueprint",
        "Canvas",
        "Folio",
        "Protocol",
        "Ink"
      ],
      "default": "Standard"
    }
  },
  "additionalProperties": false
}
